# Copy to .env for local dev, or set these in Render → Environment.

# MongoDB Atlas (required) — NOT localhost for Render deploy
# Atlas → Connect → Drivers → copy connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vendorbridge?retryWrites=true&w=majority
DB_NAME=vendorbridge

# Required on Render (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Optional
JWT_EXPIRY_HOURS=24
FLASK_ENV=production
FLASK_DEBUG=false

# Frontend URL for CORS (your Render static site URL)
FRONTEND_URL=https://your-frontend.onrender.com

# Gmail SMTP (optional, for invoice emails)
MAIL_EMAIL=
MAIL_PASSWORD=
